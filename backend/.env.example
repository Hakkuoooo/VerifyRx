# Copy this file to .env and fill in real values.

# --- External APIs ---
# Leave empty to skip VirusTotal checks during development.
VIRUSTOTAL_API_KEY=

# --- ML models ---
# Hugging Face Hub model id (or local path) for SMS classification.
# Default is a tiny pretrained SMS-spam model — works out of the box.
# Swap to the path printed by scripts/train_sms.py to use fine-tuned weights.
SMS_MODEL_NAME=mrm8488/bert-tiny-finetuned-sms-spam-detection

# Optional local path to fine-tuned ResNet-18 weights (.pt file).
# Leave empty to run the image checker in "demo mode" (ImageNet features only).
IMAGE_MODEL_PATH=
